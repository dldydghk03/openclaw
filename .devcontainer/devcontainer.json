{
  "name": "OpenClaw Anki Factory",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python"
      ],
      "settings": {
        "github.copilot.chat.codeGeneration.instructions.enabled": true,
        "python.defaultInterpreterPath": "/usr/local/bin/python3"
      }
    }
  },
  "postCreateCommand": "corepack enable && pnpm install --frozen-lockfile && .github/skills/anki-factory-quality/scripts/run-smoke.sh",
  "remoteEnv": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
