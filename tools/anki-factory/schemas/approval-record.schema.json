{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/anki-agent/approval-record.schema.json",
  "title": "Anki Factory Approval Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["approval_id", "run_id", "preview_file", "decision", "decided_at"],
  "properties": {
    "approval_id": {
      "type": "string",
      "minLength": 3
    },
    "run_id": {
      "type": "string",
      "minLength": 3
    },
    "preview_file": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["approved", "rejected", "edit_requested"]
    },
    "decided_at": {
      "type": "string"
    },
    "requested_changes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "approver": {
      "type": "string"
    }
  }
}
