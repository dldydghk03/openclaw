{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/anki-agent/rewrite-request.schema.json",
  "title": "Anki Factory Rewrite Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "created_at", "items"],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "rewrite_focus", "constraints"],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "rewrite_focus": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
