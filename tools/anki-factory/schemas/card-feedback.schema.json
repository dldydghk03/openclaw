{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/anki-agent/card-feedback.schema.json",
  "title": "Anki Factory Card Feedback",
  "type": "object",
  "additionalProperties": false,
  "required": ["feedback_id", "run_id", "candidate_id", "decision", "labels", "created_at"],
  "properties": {
    "feedback_id": {
      "type": "string",
      "minLength": 3
    },
    "run_id": {
      "type": "string",
      "minLength": 3
    },
    "candidate_id": {
      "type": "string",
      "minLength": 3
    },
    "decision": {
      "type": "string",
      "enum": ["keep", "rewrite", "delete", "split", "merge", "promote_to_playbook"]
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "good_human_tutor_style",
          "exam_useful",
          "source_grounded",
          "good_jokbo_explanation",
          "good_tcheck_handling",
          "ai_smell",
          "awkward_korean",
          "too_verbose",
          "too_thin",
          "wrong_focus",
          "source_missing",
          "format_violation",
          "bad_cloze_target",
          "needs_option_level_explanation",
          "needs_likely_confusion",
          "duplicate",
          "not_worth_carding"
        ]
      }
    },
    "comment": {
      "type": "string"
    },
    "preferred_rewrite": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    }
  }
}
